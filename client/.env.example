# Example environment variables for local development and Vercel
# Copy this file to .env and fill in real values locally (do NOT commit .env)

# Gemini / AI provider API key
GEMINI_API_KEY=

# Google Cloud / GCP API key (if required by integrations)
GCP_API_KEY=

# If you use Vite-specific env variables, prefix them with VITE_
# e.g. VITE_SOME_PUBLIC_KEY=your_value

# Notes:
# - Save secrets in Vercel's Environment Variables for production.
# - Keep `client/.env` listed in .gitignore and never commit secrets.
